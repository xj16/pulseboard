{
  "name": "@pulseboard/server",
  "version": "2.0.0",
  "private": true,
  "description": "Express + Socket.IO server with a built-in data simulator for PulseBoard.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "seed": "tsx src/seed.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "test:coverage": "c8 --reporter=text --reporter=lcov --reporter=text-summary --src src --include \"src/**/*.ts\" --exclude \"src/**/*.test.ts\" node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "c8": "^10.1.3",
    "socket.io-client": "^4.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
