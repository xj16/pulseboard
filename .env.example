# PulseBoard server configuration (all optional — sensible defaults apply)

# Port the Express + Socket.IO server listens on.
PORT=4000

# Milliseconds between simulator ticks (lower = faster charts).
TICK_MS=1000

# Allowed CORS origin for the Socket.IO server + REST API.
# Default: "*" in dev, and same-origin-only when NODE_ENV=production.
# Set an explicit origin to allow a specific cross-origin client, e.g.
# CLIENT_ORIGIN=https://pulseboard.example.com
CLIENT_ORIGIN=*

# Initial simulator scenario: calm | traffic-spike | incident | deploy-blip.
# (Can also be switched live from the toolbar.)
SCENARIO=calm

# Directory where per-room board layouts are persisted as JSON so they survive
# restarts. Set DATA_DIR="" to run fully in-memory (no persistence).
DATA_DIR=.pulseboard-data

# Set to "production" to serve the built Vue client statically from the server
# and lock CORS to same-origin by default.
# NODE_ENV=production

# --- Clients (Vite) ---
# Point a client at a non-same-origin server (leave empty to use the proxy).
# VITE_SERVER_URL=http://localhost:4000
